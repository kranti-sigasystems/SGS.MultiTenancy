@using SGS.MultiTenancy.Core.Application.DTOs
@model SGS.MultiTenancy.UI.Models.CreateRoleViewModel

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center my-4">
        <h4 class="fw-semibold mb-0">Roles Management</h4>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-circle me-2"></i> Create New Role
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Role Name</th>
                            <th class="py-3">Description</th>
                            <th class="py-3 text-center">Default</th>
                            <th class="pe-4 py-3 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RolesList != null && Model.RolesList.Any())
                        {
                            foreach (var role in Model.RolesList)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@role.Name</td>
                                    <td class="text-muted small">@role.Description</td>
                                    <td class="text-center">
                                        <span class="badge @(role.IsDefault ? "bg-success" : "bg-secondary")">
                                            @(role.IsDefault ? "Yes" : "No")
                                        </span>
                                    </td>
                                    <td class="pe-4 text-end">
                                        @if (role.TenantID != Guid.Empty)
                                        {
                                            <a asp-action="Edit" asp-route-id="@role.ID" class="btn btn-sm btn-outline-primary border-0 me-2">
                                                <i class="bi bi-pencil-square fs-5"></i>
                                            </a>
                                            <button class="btn btn-sm btn-outline-danger border-0"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteModal-@role.ID">
                                                <i class="bi bi-trash fs-5"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <i class="bi bi-lock-fill text-muted" title="System Role"></i>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">No roles found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@foreach (var role in Model.RolesList.Where(r => r.TenantID != Guid.Empty))
{
    <div class="modal fade" id="deleteModal-@role.ID" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="Id" value="@role.ID" />
                    <div class="modal-header">
                        <h5 class="modal-title">Confirm Delete</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        Are you sure you want to delete <strong>@role.Name</strong>?
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}